# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# eBay Developer credentials (Trading API)
# https://developer.ebay.com/my/keys で確認
EBAY_ENV=sandbox
EBAY_APP_ID=your-app-id
EBAY_DEV_ID=your-dev-id
EBAY_CERT_ID=your-cert-id
EBAY_AUTH_TOKEN=your-user-oauth-or-legacy-token
EBAY_SITE_ID=0
EBAY_TRADING_API_VERSION=1193

# Mercari 自動取り下げ
MERCARI_CHECK_INTERVAL_MINUTES=30
PLAYWRIGHT_HEADLESS=1
